{
  "manifest_version": 3,
  "name": "Touch Grass",
  "description": "Summarize LinkedIn posts and profiles with satire.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.linkedin.com/*", "https://api.openai.com/*"],
  "background": {
    "service_worker": "background/serviceWorker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
